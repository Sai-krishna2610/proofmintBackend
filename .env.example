# ProofMint Backend Environment Configuration Example
PORT=4000

# PostgreSQL database connection URL (Change user, pass, host, port, and dbname as needed)
DATABASE_URL=postgres://user:pass@localhost:5432/proofmint

# JWT Token Signing Secrets
JWT_ACCESS_SECRET=your_dev_access_secret_key_proofmint_2026_super_long_jwt_key
JWT_REFRESH_SECRET=your_dev_refresh_secret_key_proofmint_2026_super_long_jwt_key

# JWT Token Lifespans
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Integration and Verification Settings
PUBLIC_BASE_URL=http://localhost:5173
VERIFICATION_PATH=/verify

# Upload Directory Settings
UPLOAD_DIR=./storage
MAX_UPLOAD_MB=15

# Rate Limiting for Verification Endpoint (max requests:window duration)
VERIFY_RATE_LIMIT_MAX=20
VERIFY_RATE_LIMIT_WINDOW_MS=600000 # 10 minutes in milliseconds
